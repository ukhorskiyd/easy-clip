{
  "manifest_version": 3,
  "name": "easy-clip",
  "description": "Save any article to Markdown with Alt+S",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "clip-page": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save page as Markdown"
    }
  }
}
